CONFIG_WIRELESS_WAPI=y
CONFIG_WIRELESS_WAPI_CMDTOOL=y
CONFIG_WIRELESS_WAPI_PROGNAME="wapi"
CONFIG_WIRELESS_WAPI_STACKSIZE=2048
CONFIG_WIRELESS_WAPI_PRIORITY=100
CONFIG_WIRELESS_WAPI_SCAN_MAX_DATA=4096
